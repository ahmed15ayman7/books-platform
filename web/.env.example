# ===========================================
# Books Platform — Environment Variables
# Copy this file to .env.local and fill values
# ===========================================

# === Database ===
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/booksplatform?schema=public"

# === App ===
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# === SEO (canonical URLs, OG, site names) ===
# Production: set to your public domain (no trailing slash)
# NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXT_PUBLIC_OG_IMAGE=""
NEXT_PUBLIC_SITE_NAME_AR="منصة الكتب العالمية"
NEXT_PUBLIC_SITE_NAME_EN="Books Platform"
NEXT_PUBLIC_SITE_TAGLINE_AR="نافذة العالم على الكتب — اكتشف، اقرأ، انشر"
NEXT_PUBLIC_SITE_TAGLINE_EN="A window to world books — discover, read, publish"
NEXT_PUBLIC_TWITTER_HANDLE=""

# === JWT Auth ===
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-here"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"
JWT_ACCESS_EXPIRES_IN="5h"
JWT_REFRESH_EXPIRES_IN="7d"

# === Redis (Upstash for production / local for dev) ===
UPSTASH_REDIS_REST_URL="https://your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
# For local dev with docker Redis:
# REDIS_URL="redis://localhost:6379"

# === Email (Resend) ===
RESEND_API_KEY="re_your_api_key"
RESEND_FROM_EMAIL="noreply@booksplatform.net"
RESEND_FROM_NAME="منصة الكتب العالمية"

# === File Upload (UploadThing) ===
UPLOADTHING_TOKEN="your-uploadthing-token"

# === Web Push Notifications (VAPID) ===
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@booksplatform.net"

# === Payment (Stripe) ===
STRIPE_SECRET_KEY="sk_test_your_stripe_secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# === Payment (Paymob - Egypt) ===
PAYMOB_API_KEY=""
PAYMOB_INTEGRATION_ID=""
PAYMOB_IFRAME_ID=""

# === Analytics ===
NEXT_PUBLIC_POSTHOG_KEY="phc_your_posthog_key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
NEXT_PUBLIC_CLARITY_PROJECT_ID="your-clarity-id"

# === Meta Pixels ===
NEXT_PUBLIC_FACEBOOK_PIXEL_ID="your-fb-pixel-id"
NEXT_PUBLIC_TIKTOK_PIXEL_ID="your-tiktok-pixel-id"

# === Social API (for auto-post) ===
FACEBOOK_ACCESS_TOKEN=""
FACEBOOK_PAGE_ID=""
TWITTER_API_KEY=""
TWITTER_API_SECRET=""
TWITTER_ACCESS_TOKEN=""
TWITTER_ACCESS_SECRET=""
INSTAGRAM_ACCESS_TOKEN=""

# === AI (for description generation) ===
OPENAI_API_KEY="sk-your-openai-key"

# === WhatsApp (Twilio) ===
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""

# === Telegram ===
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHANNEL_ID=""

# === Monitoring ===
SENTRY_DSN="https://your-sentry-dsn"
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn"

# === Rate Limiting ===
# Using Upstash Redis (see above)
RATE_LIMIT_AUTH_PER_MINUTE="10"
RATE_LIMIT_API_PER_MINUTE="60"
RATE_LIMIT_SEARCH_PER_MINUTE="30"
